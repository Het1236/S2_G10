        <mxCell id="PR1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7a5000;fontColor=#ffffff;strokeColor=#4a2e00;fontSize=9;" value="&lt;b&gt;Bayes&#39; Theorem&lt;/b&gt;&lt;br&gt;P(R|Data) ∝ P(Data|R)·P(R)&lt;br&gt;Posterior ∝ Fitness(Rⱼ)" vertex="1">
