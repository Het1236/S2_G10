        <mxCell id="PSO1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4a1a7a;fontColor=#ffffff;strokeColor=#2a0a4a;fontSize=9;" value="&lt;b&gt;Velocity Update&lt;/b&gt;&lt;br&gt;Vᵢ(t+1) = w·Vᵢ(t)&lt;br&gt;+ c₁R₁(Pbest−Xᵢ) + c₂R₂(Pgbest−Xᵢ)" vertex="1">
          <mxGeometry height="80" width="250" x="2100" y="1040" as="geometry" />
