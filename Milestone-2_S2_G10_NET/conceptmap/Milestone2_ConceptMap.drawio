        <mxCell id="PR0" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#7a5000;fontColor=#ffffff;strokeColor=#4a2e00;fontSize=12;fontStyle=1;" value="&lt;b&gt;Probabilistic Reasoning&lt;/b&gt;" vertex="1">
