        <mxCell id="AM0" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a3060;fontColor=#ffffff;strokeColor=#0a1840;fontSize=12;fontStyle=1;" value="&lt;b&gt;Advanced Math Concepts&lt;/b&gt;" vertex="1">
